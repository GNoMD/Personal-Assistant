# 服务端口（默认 3001）
PORT=13222

# 监听地址（0.0.0.0 允许外网访问）
HOST=0.0.0.0

# JWT 密钥（生产环境务必修改）
JWT_SECRET=k7X9mP2vR4nL8jQ6wY3tZ1sA5bN0cE4fG7hJ9iK2mO6pU8xV

# 系统管理员用户名（逗号分隔；启动时自动标记为 admin）
ADMIN_USERNAMES=gnomd

# 数据库路径（默认 ./data/tasks.db，相对 backend 目录的上级 data/）
# DB_PATH=/var/lib/task-planner/tasks.db

# OpenClaw 智能助手（Token 只保存在服务端，禁止写入 VITE_*）
OPENCLAW_ENABLED=true
OPENCLAW_RESPONSES_URL=http://119.45.160.179:16136/v1/responses
OPENCLAW_GATEWAY_TOKEN=replace-with-your-openclaw-token
OPENCLAW_AGENT_ID=main
OPENCLAW_MODEL=openclaw/default
OPENCLAW_TIMEOUT_MS=120000
# 每用户固定 OpenClaw 窗口的近似上下文容量（字符），超限才轮换新窗口
OPENCLAW_CONTEXT_CHAR_LIMIT=120000

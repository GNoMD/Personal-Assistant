{
  "name": "task-planner",
  "version": "2.0.0",
  "private": true,
  "engines": {
    "node": ">=18",
    "npm": ">=9"
  },
  "scripts": {
    "install:all": "npm install --prefix backend && npm install --prefix frontend",
    "build": "npm run build --prefix frontend",
    "start": "npm start --prefix backend",
    "seed": "npm run seed --prefix backend",
    "pack": "npm run build && node scripts/pack-release.mjs",
    "pack:update": "npm run build && node scripts/pack-release.mjs --update",
    "pack:update:media": "npm run build && node scripts/pack-release.mjs --update --with-media",
    "pack:offline": "npm run build && node scripts/pack-release.mjs --offline",
    "deploy": "node scripts/deploy-remote.mjs",
    "deploy:full": "node scripts/deploy-remote.mjs --full",
    "deploy:restart": "node scripts/deploy-remote.mjs --restart-only"
  }
}

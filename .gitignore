# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage
*.lcov

# nyc test coverage
.nyc_output

# Grunt intermediate storage (https://gruntjs.com/creating-plugins#storing-task-files)
.grunt

# Bower dependency directory (https://bower.io/)
bower_components

# node-waf configuration
.lock-wscript

# Compiled binary addons (https://nodejs.org/api/addons.html)
build/Release

# Dependency directories
node_modules/
jspm_packages/

# Snowpack dependency directory (https://snowpack.dev/)
web_modules/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional stylelint cache
.stylelintcache

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variable files — see “Local secrets” section below
# (.env rules consolidated at bottom)

# parcel-bundler cache (https://parceljs.org/)
.cache
.parcel-cache

# Next.js build output
.next
out

# Nuxt.js build / generate output
.nuxt
dist
.output

# Gatsby files
.cache/
# Comment in the public line in if your project uses Gatsby and not Next.js
# https://nextjs.org/blog/next-9-1#public-directory-support
# public

# vuepress build output
.vuepress/dist

# vuepress v2.x temp directory
.temp

# Sveltekit cache directory
.svelte-kit/

# vitepress build output
**/.vitepress/dist

# vitepress cache directory
**/.vitepress/cache

# Docusaurus cache and generated files
.docusaurus

# Serverless directories
.serverless/

# FuseBox cache
.fusebox/

# DynamoDB Local files
.dynamodb/

# Firebase cache directory
.firebase/

# TernJS port file
.tern-port

# Stores VSCode versions used for testing VSCode extensions
.vscode-test

# pnpm
.pnpm-store

# yarn v3
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Vite files
vite.config.js.timestamp-*
vite.config.ts.timestamp-*
.vite/

# ===== Local secrets & runtime data (do not commit) =====
# Environment / credentials
.env
.env.*
!.env.example
!.env.*.example
task-planner/.deploy.env
*.pem
*.key
*.p8
*.p12
*.pfx
*.jks
*.keystore
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
*.secret
credentials.json
secrets.json
**/secrets/
**/credentials/
serviceAccount*.json
*-firebase-adminsdk*.json
.aws/
.gcloud/

# SQLite databases & WAL sidecars (contain users / password hashes)
*.db
*.db-shm
*.db-wal
*.db.bak
*.sqlite
*.sqlite3
*.sql.gz
*backup*.sql
dump.sql
*.dump

# Task Planner runtime data directory (SQLite live files)
task-planner/data/*
!task-planner/data/.gitkeep
task-planner/backend/data/
task-planner/release/**/data/

# Packaged release (generated by `npm run pack`; may embed build + local paths)
task-planner/release/
*.zip

# Travel spot photo binaries (download locally / deploy as a folder; do not commit)
task-planner/frontend/public/travel-spot-photos/**
!task-planner/frontend/public/travel-spot-photos/.gitkeep
!task-planner/frontend/public/travel-spot-photos/README.md

# Vite / local build output (including ad-hoc outDir names)
task-planner/frontend/dist/
task-planner/frontend/dist-*/
task-planner/frontend/dist-check-tmp/
task-planner/frontend/dist-verify-hub/
task-planner/frontend/dist-js-only/

# OS / editor junk
.DS_Store
Thumbs.db
desktop.ini
.idea/

# Local overrides & process dumps
*.local
!*.local.example
.pm2/
dump.pm2
ecosystem.config.local.*
